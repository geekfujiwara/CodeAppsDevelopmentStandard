# Power Platform 環境設定
DATAVERSE_URL=https://{org}.crm7.dynamics.com/
TENANT_ID={your-tenant-id}

# ソリューション設定（プロジェクトに合わせて変更）
SOLUTION_NAME={YourSolutionName}
SOLUTION_DISPLAY_NAME={ソリューション表示名}
PUBLISHER_PREFIX={prefix}

# PAC CLI 認証プロファイル
PAC_AUTH_PROFILE={YourProfileName}

# Power Pages サイト設定（デプロイスクリプト用）
PAGES_SITE_NAME={SiteName}
PAGES_SUBDOMAIN={subdomain}
PORTAL_TABLE_LOGICAL={prefix}_incident

# Power Pages サイト ID（PP API での再起動・アクティブ化に使用）
# 取得元: GET https://api.powerplatform.com/powerpages/environments/{ENV_ID}/websites?api-version=2024-10-01 の value[].id
# 注意: powerpages.config.json の siteName と PP API 登録名が異なると deploy_site.py の
#       自動再起動が名前照合に失敗するため、この ID で明示的に再起動する。
PAGES_WEBSITE_ID={website-id}

# メール通知先（Power Automate フロー用・オプション）
ADMIN_EMAIL=admin@example.com

# Copilot Studio Bot ID（Phase 3・オプション）
BOT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BOT_SCHEMA={prefix}_{botname}

# === Power Automate フロー用（オプション）===

# 接続 ID（Power Automate > 接続 で確認）
DATAVERSE_CONN=
OUTLOOK_CONN=

# 接続参照の論理名（Copilot Studio UI で確認）
CONNREF_COPILOT=
CONNREF_OUTLOOK=

# フロー Workflow ID（修正スクリプト用）
FLOW_WORKFLOW_ID=
WF_ID=
ENV_ID=

# === SharePoint 連携フロー用（オプション）===
SP_SITE_URL=https://YOUR_TENANT.sharepoint.com/sites/YOUR_SITE
SP_LIBRARY_ID=
SP_FOLDER_PATH=/Shared Documents/All

# === AI Builder（オプション）===
AI_MODEL_ID=

# === Teams 連携（オプション）===
TEAMS_GROUP_ID=
TEAMS_CHANNEL_ID=

# === フォールバック接続 ID（PowerApps API タイムアウト対策・オプション）===
FALLBACK_CONN_DATAVERSE=
FALLBACK_CONN_SHAREPOINT=
FALLBACK_CONN_TEAMS=
FALLBACK_CONN_ONEDRIVE=
