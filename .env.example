# Power Platform 環境設定（必須）
DATAVERSE_URL=https://{org}.crm.dynamics.com/
TENANT_ID={your-tenant-id}
ENV_ID={your-environment-id}

# ソリューション設定（必須 — テーマに合わせて変更）
SOLUTION_NAME={YourSolutionName}
SOLUTION_DISPLAY_NAME={ソリューション表示名}
PUBLISHER_PREFIX={prefix}

# === Code Apps 表示設定（Vite でクライアントへ埋め込み）===
# テーマ開発時に .env で上書きする。秘密情報は入れないこと。
VITE_CODEAPPS_APP_NAME={アプリ名}
VITE_CODEAPPS_APP_SUBTITLE={サブタイトル}
VITE_CODEAPPS_DOCUMENT_TITLE={ブラウザタイトル}
VITE_CODEAPPS_THEME_STORAGE_KEY=app-theme
# ナビゲーション構成（JSON 配列）— テーマのページ構成に合わせて定義する
# 例: [{"category":"メイン","items":[{"label":"ホーム","path":"dashboard","iconKey":"dashboard"}]}]
# VITE_CODEAPPS_NAV_SECTIONS_JSON=

# PAC CLI 認証プロファイル
PAC_AUTH_PROFILE={YourProfileName}

# Power Pages サイト設定（デプロイスクリプト用）
PAGES_SITE_NAME={SiteName}
PAGES_SUBDOMAIN={subdomain}
PORTAL_TABLE_LOGICAL={prefix}_incident

# 報告者 Contact Lookup 設定（setup_inquiry_reporter.py 用）
# Power Pages では createdby はアプリユーザーになるため、報告者は Contact Lookup で追跡する。
# REPORTER_LOOKUP_ATTR と REPORTER_RELATIONSHIP_SCHEMA はデフォルトが自動生成されるため
# 変更が必要な場合のみ設定する。
# REPORTER_LOOKUP_ATTR={prefix}_inquirerid
# REPORTER_RELATIONSHIP_SCHEMA={prefix}_inquiry_contact

# Power Pages サイト ID（PP API での再起動・アクティブ化に使用）
# 取得元: GET https://api.powerplatform.com/powerpages/environments/{ENV_ID}/websites?api-version=2024-10-01 の value[].id
# 注意: powerpages.config.json の siteName と PP API 登録名が異なると deploy_site.py の
#       自動再起動が名前照合に失敗するため、この ID で明示的に再起動する。
PAGES_WEBSITE_ID={website-id}

# Power Pages サブドメイン（PAGES_WEBSITE_ID 未設定時の再起動フォールバック）
PP_SUBDOMAIN={subdomain}

# デプロイスクリプト設定（deploy_site.py / relink_table_permissions.py 用・オプション）
# PORTAL_DIR          : ポータルディレクトリ（未設定時は リポジトルート/portal）
# RELINK_WEBROLE_NAMES: upload-code-site で消えたテーブル権限に再付与する Web ロール名
#                       （部分一致・カンマ区切り。既定: Authenticated）
PORTAL_DIR=
RELINK_WEBROLE_NAMES=Authenticated

# メール通知先（Power Automate フロー用・オプション）
ADMIN_EMAIL=admin@example.com

# Copilot Studio Bot ID（Phase 3・オプション）
BOT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BOT_SCHEMA={prefix}_{botname}

# === Power Automate フロー用（オプション）===

# 接続 ID（Power Automate > 接続 で確認）
DATAVERSE_CONN=
OUTLOOK_CONN=

# 接続参照の論理名（Copilot Studio UI で確認）
CONNREF_COPILOT=
CONNREF_OUTLOOK=

# フロー Workflow ID（修正スクリプト用）
FLOW_WORKFLOW_ID=
WF_ID=
ENV_ID=

# === Power Pages サイト（オプション）===
# Power Pages サイト ID（PP API での再起動・アクティブ化に使用）
# 取得元: GET https://api.powerplatform.com/powerpages/environments/{ENV_ID}/websites?api-version=2024-10-01
# 注意: powerpages.config.json の siteName と PP API 登録名が異なると deploy_site.py の
#       自動再起動が名前照合に失敗するため、この ID で明示的に再起動する。
PAGES_WEBSITE_ID=

# === SharePoint 連携フロー用（オプション）===
SP_SITE_URL=https://YOUR_TENANT.sharepoint.com/sites/YOUR_SITE
SP_LIBRARY_ID=
SP_FOLDER_PATH=/Shared Documents/All

# === AI Builder（オプション）===
AI_MODEL_ID=

# === Teams 連携（オプション）===
TEAMS_GROUP_ID=
TEAMS_CHANNEL_ID=

# === フォールバック接続 ID（PowerApps API タイムアウト対策・オプション）===
FALLBACK_CONN_DATAVERSE=
FALLBACK_CONN_SHAREPOINT=
FALLBACK_CONN_TEAMS=
FALLBACK_CONN_ONEDRIVE=
