# copilot-studio-v2 スクリプトが使うパラメータ定義（実値は .env に置く）

# Dataverse 環境 URL（取得元: Power Platform 管理センター > 環境 > URL）
DATAVERSE_URL=https://<org>.crm.dynamics.com
# テナント ID（取得元: Entra ID > 概要 > テナント ID）
TENANT_ID=<tenant-guid>

# 任意: ソリューション運用する場合（指定時 MSCRM.SolutionName ヘッダを付与）
SOLUTION_NAME=SampleSolution
PUBLISHER_PREFIX=geek

# create_agent.py 用パラメータ
AGENT_NAME=my-new-agent
AGENT_SCHEMA=geek_mynewagent
AGENT_MODEL_SERIES=Sonnet46
AGENT_INSTRUCTIONS=ここにエージェントの指示文を記載します。

# attach_skill.py / set_icon.py / publish_agent.py / verify_agent.py / analyze_agent.py 用
# 未指定なら create_agent.py が出力する agent_botid.txt を読む
AGENT_BOTID=<bot-guid>
SKILL_DIR=skill
SKILL_NAME=geek-pptx-py
SKILL_DESCRIPTION=フラット Python スキルの説明（Use when: ... を含める）

# set_icon.py 用（任意。汎用アイコン: 角丸背景＋頭文字＋アクセントバッジ）
# 取得元: 任意。ICON_TEXT 未指定ならエージェント名の先頭1文字を使用
ICON_TEXT=A
ICON_BG_COLOR=#2563EB
ICON_ACCENT_COLOR=#22C55E

# set_app_details.py 用（Publish ＞ Teams + M365 ＞ Edit details の各項目）
# 保存先は PVA bot management ゲートウェイ（Dataverse ではない）。アイコンもここに保存される。
# 未指定は妥当なデフォルトを自動補完（Short は Instructions の1文目、リンクは Copilot Studio 標準 fwlink）。
APP_SHORT_DESCRIPTION=このエージェントの短い説明（80字以内・必須相当）
APP_LONG_DESCRIPTION=このエージェントの長い説明（3400字以内）
# M365 Copilot のディスクレーマー文（任意・空可）
APP_DISCLAIMER=
APP_DEVELOPER_NAME=Your Company
APP_WEBSITE_URL=https://example.com
APP_TERMS_URL=https://example.com/terms
APP_PRIVACY_URL=https://example.com/privacy
APP_MPN_ID=
# Power Platform store に表示するか（true/false, 既定 false）
APP_STORE_DISCOVERABLE=false
# Teams で利用できる範囲: personal,team,groupchat のカンマ区切り（personal は常に付与）
APP_TEAMS_SCOPES=personal,team,groupchat
# 通話対応（true/false, 既定 false）
APP_SUPPORTS_CALLING=false
# Teams Resource Account ID（calling 用 / 任意）
APP_TEAMS_RA_ID=
# SSO Application(client) ID（GUID / 任意）と Resource URI（任意）
APP_SSO_CLIENT_ID=
APP_SSO_RESOURCE_URI=
# M365 Copilot で利用可能にするか（true/false, 既定 true）
APP_M365_ENABLED=true
# true なら自動補完が発生した時点で停止し、値の手動確認を促す（CI 向け）
APP_DETAILS_REQUIRE_CONFIRM=false
# PVA ゲートウェイ URL / BAP 環境 ID の明示指定（任意・通常は BAP API から自動取得）
PVA_GATEWAY_BASE=
BAP_ENVIRONMENT_ID=

# add_mcp_server.py 用（既定は Dataverse MCP）
MCP_CONNECTOR=shared_commondataserviceforapps
MCP_DISPLAY=Microsoft Dataverse MCP サーバー
# add_mcp_server.py の operationId は Swagger 自動検出。明示する場合のみ設定
# MCP_OPERATION=InvokeMCP

# deploy_agent.py の MCP 一括追加（"connector|表示名" をカンマ区切り）
# 例: shared_commondataserviceforapps|Microsoft Dataverse MCP サーバー,shared_workiqonedrive|Work IQ OneDrive (Preview)
MCP_CONNECTORS=shared_commondataserviceforapps|Microsoft Dataverse MCP サーバー
