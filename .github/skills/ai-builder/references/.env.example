# ai-builder — 環境変数サンプル
# このファイルはプレースホルダーのみ。実値はリポジトリルートの .env に置く（.gitignore 済み）。
# 値は scripts/deploy_ai_prompt.py が参照する。共通変数（DATAVERSE_URL / TENANT_ID 等）は
# standard/references/.env.example も参照。

# === Power Platform 環境（必須）===
# 取得元: Power Platform 管理センター > 環境 > 環境 URL
DATAVERSE_URL=https://{org}.crm.dynamics.com/

# === ソリューション設定（必須）===
# 取得元: pac solution list または メーカーポータル > ソリューション
SOLUTION_NAME={YourSolutionName}
# 取得元: メーカーポータル > 発行元 のカスタマイズプレフィックス
PUBLISHER_PREFIX={prefix}

# === AI Prompt 設定 ===
# AI プロンプトの表示名（任意・既定: スクリプト内定数）
AI_PROMPT_NAME=AI Prompt Sample

# プロンプトを追加するエージェントの Bot ID または Copilot Studio の overview URL
# 取得元: Copilot Studio > エージェント > 設定（URL の bots/{guid} 部分）
# BOT_ID と異なるエージェントに追加する場合のみ指定（未指定時は BOT_ID を使用）
AI_PROMPT_BOT_ID=https://copilotstudio.microsoft.com/.../bots/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/overview
