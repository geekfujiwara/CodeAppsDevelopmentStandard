# ==========================================================
# geek-quote（見積・請求管理）— カスタマイズガイド
# ==========================================================
# このファイルをプロジェクトルートの .env にコピーして値を入力してください。
# 共通 .env.example（.github/skills/standard/references/.env.example）に記載の共通変数（DATAVERSE_URL / TENANT_ID 等）も別途必要です。
# ==========================================================

# ── アプリ表示（変更推奨） ──────────────────────────────────
# アプリ名は見積書プレビューの発行元表示にも使われます
VITE_CODEAPPS_APP_NAME=見積・請求管理ポータル
VITE_CODEAPPS_APP_SUBTITLE=見積作成・請求追跡
VITE_CODEAPPS_DOCUMENT_TITLE=見積・請求管理ポータル
# ナビゲーション構成は src/config.ts に直接記述（env var では管理しない）

# ── 機能フラグ（変更推奨） ──────────────────────────────────
# true にすると対応タブ・機能が表示されます
VITE_FEATURE_INVOICES=false         # 請求管理ページ + 受注見積からの請求作成ボタン
VITE_FEATURE_REPORTS=false          # レポートページ（ステータス別・取引先別・月別受注率）
