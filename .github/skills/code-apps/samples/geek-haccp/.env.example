# ==========================================================
# geek-haccp（飲食・HACCP 温度/衛生点検）— カスタマイズガイド
# ==========================================================
# このファイルをプロジェクトルートの .env にコピーして値を入力してください。
# 共通 .env.example（.github/skills/standard/references/.env.example）に記載の共通変数（DATAVERSE_URL / TENANT_ID 等）も別途必要です。
# ==========================================================

# ── アプリ表示（変更推奨） ──────────────────────────────────
VITE_CODEAPPS_APP_NAME=衛生管理ポータル
VITE_CODEAPPS_APP_SUBTITLE=HACCP 温度・衛生点検記録
VITE_CODEAPPS_DOCUMENT_TITLE=衛生管理ポータル
# ナビゲーション構成は src/config.ts に直接記述（env var では管理しない）

# ── 機能フラグ（変更推奨） ──────────────────────────────────
# true にすると対応タブ・機能が表示されます
VITE_FEATURE_CHECKPOINTS=false      # 点検項目マスタページ（カテゴリ・単位・管理基準の上下限、標準項目の一括投入）
VITE_FEATURE_REPORTS=false          # レポートページ（項目別適合率・項目×時間帯 逸脱ヒートマップ）
