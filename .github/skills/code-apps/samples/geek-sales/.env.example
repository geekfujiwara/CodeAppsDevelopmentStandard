# ==========================================================
# geek-sales（営業支援・Copilot Analytics）— カスタマイズガイド
# ==========================================================
# このファイルをプロジェクトルートの .env にコピーして値を入力してください。
# 共通 .env.example（.github/skills/standard/references/.env.example）に記載の共通変数（DATAVERSE_URL / TENANT_ID 等）も別途必要です。
# ==========================================================

# ── アプリ表示（変更推奨） ──────────────────────────────────
VITE_CODEAPPS_APP_NAME=営業支援ポータル
VITE_CODEAPPS_APP_SUBTITLE=Copilot Analytics & 営業管理
VITE_CODEAPPS_DOCUMENT_TITLE=営業支援ポータル

# ── 機能フラグ（変更推奨） ──────────────────────────────────
# true にすると対応タブ・機能が表示されます

# Copilot Analytics（会話ダッシュボード・会話一覧・エージェント管理ページ）
# 取得元: Copilot Studio > 設定 > 詳細 で BOT_ID / BOT_SCHEMA を確認してから有効化
VITE_FEATURE_COPILOT=false

# AI フロー連携（メール下書き生成・アポイント提案・テリトリーニュース生成）
# 取得元: Power Automate でフローを作成後、FLOW_WORKFLOW_ID を設定してから有効化
VITE_FEATURE_AI_FLOW=false

# ── Copilot Studio（VITE_FEATURE_COPILOT=true の場合必須） ────
# 取得元: Copilot Studio > 設定 > 詳細 > スキーマ名
BOT_ID=
BOT_SCHEMA=

# ── Power Automate フロー（VITE_FEATURE_AI_FLOW=true の場合必須） ──
# 取得元: Power Automate > フロー詳細 URL の /workflows/{ここ}
FLOW_WORKFLOW_ID=
# 取得元: Power Automate > 接続 > 該当接続の URL 末尾の ID
OUTLOOK_CONN=
# 取得元: Power Automate > ソリューション > 接続参照 > 論理名
CONNREF_OUTLOOK=
