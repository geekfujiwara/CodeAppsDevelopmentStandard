# power-pages — 環境変数サンプル
# このファイルはプレースホルダーのみ。実値はリポジトリルートの .env に置く（.gitignore 済み）。
# 値は scripts/（deploy_site.py / setup_auth.py / setup_permissions.py 等）が参照する。

# === Power Platform 環境（必須）===
# 取得元: Power Platform 管理センター > 環境
DATAVERSE_URL=https://{org}.crm.dynamics.com/
TENANT_ID={your-tenant-id}
ENV_ID={your-environment-id}

# === ソリューション設定 ===
SOLUTION_NAME={YourSolutionName}
PUBLISHER_PREFIX={prefix}

# === PAC CLI 認証プロファイル ===
# 取得元: pac auth list（アクティブなプロファイル名）
PAC_AUTH_PROFILE={YourProfileName}

# === Power Pages サイト設定 ===
# サイト ID（取得元: GET https://api.powerplatform.com/powerpages/environments/{ENV_ID}/websites?api-version=2024-10-01 の value[].id）
PAGES_WEBSITE_ID={website-id}
# サブドメイン（PAGES_WEBSITE_ID 未設定時の再起動フォールバック）
PP_SUBDOMAIN={subdomain}
# .powerpages-site ディレクトリのパス（未設定時は規定の探索）
POWERPAGES_SITE_PATH=
PORTAL_DIR=
PORTAL_ROOT=

# === テーブル権限 / 認証セットアップ（オプション）===
# 公開対象テーブルの論理名
PORTAL_TABLE_LOGICAL={prefix}_incident
# Web ロール名（relink_table_permissions.py で再付与する対象・部分一致カンマ区切り）
RELINK_WEBROLE_NAMES=Authenticated
# Contact の Web API 有効化フィールド（カンマ区切り）
CONTACT_WEBAPI_FIELDS=

# === 報告者 Contact Lookup（setup_inquiry_reporter.py 用・オプション）===
# 既定が自動生成されるため、変更が必要な場合のみ設定する
REPORTER_LOOKUP_ATTR=

# === デプロイ制御（オプション）===
# DEPLOY_ENV: デプロイ先環境の識別子 / SKIP_REMOTE: リモート処理スキップ（true/空）
DEPLOY_ENV=
SKIP_REMOTE=
