# cowork — 環境変数サンプル
# このファイルはプレースホルダーのみ。実値はリポジトリルートの .env に置く（.gitignore 済み）。
# 値は scripts/register_mcp_client.py が参照する（引数でも指定可）。

# === 発行元プレフィックス ===
# 取得元: メーカーポータル > 発行元 のカスタマイズプレフィックス
PUBLISHER_PREFIX={prefix}

# === Power Platform 環境 ===
# 取得元: Power Platform 管理センター > 環境 > 環境 URL / テナント
DATAVERSE_URL=https://{org}.crm.dynamics.com/
TENANT_ID={tenant-guid}

# === Cowork OAuth クライアント（MCP クライアント登録用）===
# 取得元: setup_entra_oauth_graph.py（推奨）または setup_entra_oauth.ps1 が自動書き込み
COWORK_OAUTH_CLIENT_ID={client-id}
# クライアントシークレット（機密。スクリプトが自動書き込み。Git にコミットしない）
COWORK_OAUTH_CLIENT_SECRET={client-secret}
# Teams 開発者ポータルの OAuth client registration ID（Step 5 で取得。manifest の referenceId）
COWORK_OAUTH_REGISTRATION_ID={registration-id}
