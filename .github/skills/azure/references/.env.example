# azure スキル — 環境変数サンプル（プレースホルダーのみ。実値はリポジトリルートの .env に置く。.gitignore 済み）
# 値は scripts/*.ps1 が引数未指定時のデフォルトとして参照する。実 GUID・シークレット・固有名は書かない。

# === 共通 ===
# 取得元: az group list / 対象リソースグループ
RG=<RESOURCE_GROUP>
# 取得元: データストレージと同一リージョン（VNet 統合はコンピュートと同一リージョン必須）
REGION=<REGION>            # 例: japaneast

# === ネットワーク ===
VNET=<VNET_NAME>
PE_SUBNET=<PE_SUBNET_NAME>        # Private Endpoint 用サブネット
FUNC_SUBNET=<FUNC_SUBNET_NAME>    # コンピュート VNet 統合用サブネット（委任）
DNS_LINK=<DNS_LINK_NAME>          # Private DNS ゾーンの VNet リンク名

# === ストレージ ===
DATA_STORAGE=<DATA_STORAGE_ACCOUNT>   # 業務データ用（publicNetworkAccess=Disabled）
FUNC_STORAGE=<FUNC_STORAGE_ACCOUNT>   # バックエンド稼働用（Functions 使用時）

# === コンピュート / フロント ===
FUNCTION_APP=<FUNCTION_APP_NAME>      # バックエンド API（Functions 等）
FRONTEND=<FRONTEND_NAME>              # 公開フロント（静的サイト等）

# === シークレット管理 ===
KEY_VAULT=<KEY_VAULT_NAME>            # シークレットは Key Vault 参照で解決（appsettings に実値を書かない）
