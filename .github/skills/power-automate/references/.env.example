# power-automate — 環境変数サンプル
# このファイルはプレースホルダーのみ。実値はリポジトリルートの .env に置く（.gitignore 済み）。
# 値は scripts/ の各 deploy_flow*.py / add_flow_to_solution.py が参照する。

# === Power Platform 環境（必須）===
# 取得元: Power Platform 管理センター > 環境 > 環境 URL
DATAVERSE_URL=https://{org}.crm.dynamics.com/

# === ソリューション設定（必須）===
# 取得元: pac solution list または メーカーポータル > ソリューション
SOLUTION_NAME={YourSolutionName}
# 取得元: メーカーポータル > 発行元 のカスタマイズプレフィックス
PUBLISHER_PREFIX={prefix}

# === フロー（add_flow_to_solution.py 用・オプション）===
# フロー Workflow ID（取得元: 対象フローの URL / Dataverse workflow レコード。引数でも指定可）
FLOW_WORKFLOW_ID={workflow-id}

# === 通知先（オプション）===
# メール通知先（取得元: 運用ルールで決定）
ADMIN_EMAIL=admin@example.com

# === AI Builder（オプション）===
# 取得元: メーカーポータル > AI モデル
AI_MODEL_ID={ai-model-id}

# === SharePoint 連携（deploy_flow_sp_*.py 用・オプション）===
SP_SITE_URL=https://{tenant}.sharepoint.com/sites/{site}
SP_LIBRARY_ID={library-id}
SP_FOLDER_PATH=/Shared Documents/All

# === Teams 連携（オプション）===
# 取得元: Teams のチャネル URL / Graph API
TEAMS_GROUP_ID={group-id}
TEAMS_CHANNEL_ID={channel-id}

# === フォールバック接続 ID（PowerApps API タイムアウト対策・オプション）===
# 取得元: Power Automate > 接続 で確認。通常は deploy_flow.py が自動検索するため未設定で可
FALLBACK_CONN_DATAVERSE=
FALLBACK_CONN_SHAREPOINT=
FALLBACK_CONN_TEAMS=
FALLBACK_CONN_ONEDRIVE=
