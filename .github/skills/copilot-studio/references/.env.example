# copilot-studio — 環境変数サンプル
# このファイルはプレースホルダーのみ。実値はリポジトリルートの .env に置く（.gitignore 済み）。
# 値は scripts/ の各スクリプト（deploy_agent.py / deploy_news_agent.py / deploy_email_trigger.py 等）が参照する。

# === Power Platform 環境（必須）===
# 取得元: Power Platform 管理センター > 環境
DATAVERSE_URL=https://{org}.crm.dynamics.com/
TENANT_ID={your-tenant-id}
ENV_ID={your-environment-id}

# === ソリューション設定（必須）===
# 取得元: pac solution list または メーカーポータル > ソリューション
SOLUTION_NAME={YourSolutionName}
SOLUTION_DISPLAY_NAME={ソリューション表示名}
# 取得元: メーカーポータル > 発行元 のカスタマイズプレフィックス
PUBLISHER_PREFIX={prefix}

# === エージェント（Bot）設定 ===
# 取得元: Copilot Studio > エージェント > 設定（URL の bots/{guid}）。URL 全体の貼り付けも可。
BOT_ID=https://copilotstudio.microsoft.com/.../bots/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/overview
# 取得元: エージェントの schemaname（{prefix}_{botname}）
BOT_SCHEMA={prefix}_{botname}

# === セキュリティ（認証）設定（set_agent_security.py 用）===
# 認証モード。認証変更は公開後に反映される。
#   none      … 認証なし（匿名アクセス／Web 埋め込みに必須）  authenticationmode=2
#   microsoft … Microsoft で認証（Teams + M365・UI 既定）      authenticationmode=1
AGENT_AUTH_MODE=none

# === チャネル選択（set_agent_channels.py 用）===
# 公開先チャネルをカンマ区切りで指定。
#   web     … Web / カスタムアプリ（DirectLine・認証なしで埋め込み可）
#   teams   … Microsoft Teams（Microsoft 認証が前提）
#   copilot … Microsoft 365 Copilot（Microsoft 認証が前提）
AGENT_CHANNELS=web

# === メールトリガー連携（deploy_email_trigger.py / setup_email_trigger.py 用・オプション）===
# 通知先メール（取得元: 運用ルールで決定）
ADMIN_EMAIL=admin@example.com
# 接続参照の論理名（取得元: Copilot Studio UI > 接続参照）
CONNREF_COPILOT={prefix}_copilotConnRef
CONNREF_OUTLOOK={prefix}_outlookConnRef
# フロー Workflow ID（取得元: 対象フローの URL / Dataverse workflow レコード）
FLOW_WORKFLOW_ID={workflow-id}
WF_ID={workflow-id}

# === 外部公開 Web サイト（deploy_website.py 用・オプション）===
# 取得元: Azure ポータル > サブスクリプション（省略時は最初の有効サブスクリプションを使用）
AZURE_SUBSCRIPTION_ID={subscription-id}
# 取得元: 任意（存在しなければ自動作成）
AZURE_RESOURCE_GROUP=rg-agent-website
AZURE_LOCATION=japaneast
# 取得元: 任意の一意名（3-24 文字・小文字英数字・グローバル一意。存在しなければ自動作成）
AZURE_STORAGE_ACCOUNT={mystorageaccount}
# アカウントキー方式を使う場合のみ（共有キーがポリシーで禁止されていない環境）
AZURE_STORAGE_KEY={account-key}
# WebChat SDK トークンエンドポイント（ホストは ENV_ID のハイフン除去 32 桁を「先頭30.末尾2」に分割）
WEBCHAT_TOKEN_ENDPOINT=https://{env30}.{env2}.environment.api.powerplatform.com/powervirtualagents/botsbyschema/{BOT_SCHEMA}/directline/token?api-version=2022-03-01-preview

# === 外部公開 手動認証 / SSO（setup_webchat_auth.py / add_fic.py 用・オプション）===
# サイト URL（キャンバスアプリの SPA リダイレクト。deploy_website.py が設定する静的サイト URL）
WEBSITE_URL=https://{mystorageaccount}.z11.web.core.windows.net/
# アプリ登録の表示名（任意・既定 WebChat-Auth / WebChat-Canvas）
WEBCHAT_AUTH_APP_NAME=WebChat-Auth
WEBCHAT_CANVAS_APP_NAME=WebChat-Canvas
# 以下 3 つは setup_webchat_auth.py が自動で書き込む（手入力不要）
WEBCHAT_AUTH_APP_ID={auth-app-client-id}
WEBCHAT_CANVAS_APP_ID={canvas-app-client-id}
WEBCHAT_AUTH_SCOPE_URI=api://{auth-app-client-id}/access_as_user
