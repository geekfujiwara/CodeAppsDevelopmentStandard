# update-skills — 環境変数サンプル
# このファイルはプレースホルダーのみ。実値はリポジトリルートの .env に置く（.gitignore 済み）。
# 値は scripts/*.py が引数未指定時のデフォルトとして参照する。

# === PR 対象リポジトリ（manage_skill_pr.py / publish_skill.py 用）===
# 取得元: GitHub のリポジトリ URL（owner/repo 形式）
# 注: スキルを編集している作業ディレクトリと PR 先リポジトリは**別でもよい**。
#     publish_skill.py がこのリポジトリを一時 clone して PR を作る。
SKILL_PR_REPO={owner}/{repo}

# PR のベースブランチ（取得元: 対象リポジトリの既定ブランチ）
SKILL_PR_BASE_BRANCH=main

# 作業リポジトリ内のスキル配置ディレクトリ（リポジトリルートからの相対パス）
SKILLS_DIR=.github/skills
